# ─── Claude Max API Proxy ────────────────────────────────────────────
# Copy this file to `.env` (local dev) or set these as Railway variables.
# Never commit real values — `.env` is gitignored.

# REQUIRED in production: bearer token clients must send as
# "Authorization: Bearer <value>". If unset, /v1 endpoints are OPEN.
# Generate a long random one: `openssl rand -hex 32`
PROXY_API_KEY=

# REQUIRED for deploys: Claude Code credentials.
# Pick ONE of the two options below.

# Option A (recommended): paste the full contents of your local
# ~/.claude/.credentials.json file as a single JSON string.
# On macOS, if the file doesn't exist, get it from Keychain:
#   security find-generic-password -s "Claude Code-credentials" -w
CLAUDE_CREDENTIALS_JSON=

# Option B: just the OAuth access token. The CLI reads this env var directly.
# CLAUDE_CODE_OAUTH_TOKEN=

# Optional: port to listen on. Railway injects PORT automatically.
# PORT=3456

# Optional: bind host. Defaults to 0.0.0.0 when PORT is set, else 127.0.0.1.
# HOST=0.0.0.0
